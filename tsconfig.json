{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "useDefineForClassFields": false,
    "baseUrl": "./",
    "paths": {
      "@learning-engine/semantic-analyzer": ["packages/semantic-analyzer/src/index.ts"],
      "@learning-engine/rules-engine": ["packages/rules-engine/src/index.ts"],
      "@learning-engine/learning-state": ["packages/learning-state/src/index.ts"],
      "@learning-engine/overlay-system": ["packages/overlay-system/src/index.ts"],
      "@learning-engine/test-integration": ["packages/test-integration/src/index.ts"],
      "@learning-engine/angular-signals-adapter": ["adapters/angular-signals/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
